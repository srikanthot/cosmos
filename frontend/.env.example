# =============================================================================
# Frontend environment variables — copy to frontend/.env
# =============================================================================

# URL of the backend FastAPI app
# Local dev:   http://localhost:8000
# Azure:       https://<backend-app-name>.azurewebsites.us
BACKEND_URL=http://localhost:8000

# Optional: URL shown as a feedback button in the sidebar (leave blank to hide)
FEEDBACK_URL=

# Optional: send this value as X-Debug-User-Id header on every backend request.
# Lets you simulate different named users during local testing without real auth.
# Clear or remove this to use the backend's DEFAULT_LOCAL_USER_ID instead.
# Example: DEBUG_USER_ID=alice
DEBUG_USER_ID=local-dev
